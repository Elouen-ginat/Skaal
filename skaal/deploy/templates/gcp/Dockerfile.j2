# Generated by `skaal build` from skaal/deploy/templates/gcp/Dockerfile.j2.
# Edits to this file are overwritten on the next build.
FROM python:{{ python_version }}-slim

WORKDIR /app

RUN pip install --no-cache-dir uv

{% if dev_skaal_source -%}
# `--dev` mode: ship the local skaal checkout inside the image so the
# pre-PyPI alpha is exercised end-to-end without a TestPyPI release.
COPY _skaal_src ./_skaal_src
{% endif -%}
COPY pyproject.toml ./
RUN uv pip install --no-cache --system -r pyproject.toml

COPY {{ user_package }} ./{{ user_package }}
COPY bootstrap.py handler.py runtime_bindings.json ./

ENV SKAAL_APP={{ app_name }}
ENV SKAAL_ENV={{ env_name }}
ENV SKAAL_TARGET={{ target }}
ENV SKAAL_BOUND_FINGERPRINT={{ bound_fingerprint }}
ENV PORT=8080

# Cloud Run expects an HTTP server on $PORT. `handler.app` is a Starlette
# ASGI application that mounts FUNCTION / ASGI_SERVICE / SCHEDULE / JOB
# endpoints under stable paths the deploy synth modules know how to address.
EXPOSE 8080
CMD ["sh", "-c", "uvicorn handler:app --host 0.0.0.0 --port ${PORT:-8080}"]
