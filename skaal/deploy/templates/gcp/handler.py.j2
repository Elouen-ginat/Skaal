"""Cloud Run entry point generated by `skaal build`.

Rendered from `skaal/deploy/templates/gcp/handler.py.j2`, once per
`BoundResource`. Resource identity is fixed at build time and templated
in below — no env-var lookup, no string parsing at invocation time.

Exposes a Starlette `app` ASGI object that Cloud Run's HTTP listener
serves via Uvicorn. Routes:

- `POST /_skaal/fn/<bare_name>` — direct function invocation (Cloud Run
  service URL invoked from peer FUNCTIONs, the local runtime, or
  ad-hoc HTTP clients).
- `POST /_skaal/schedule/<bare_name>` — Cloud Scheduler target.
- `POST /_skaal/job/<bare_name>` — Cloud Tasks target.
- `/<path>` (catch-all) — the user's mounted ASGI service, when the
  resource kind is `asgi_service`.

Edits to this file are overwritten on the next build.
"""

from __future__ import annotations

import asyncio
import json
from typing import Any

from starlette.applications import Starlette
from starlette.requests import Request
from starlette.responses import JSONResponse
from starlette.routing import Mount, Route

from bootstrap import load_app, warm_up

_APP = load_app()
warm_up(_APP)

_RESOURCE_ID = "{{ resource_id }}"
_KIND = "{{ resource_kind }}"
_BARE_NAME = "{{ resource_bare_name }}"


def _resolve_callable() -> Any:
    for registry in (
        getattr(_APP, "_functions", {}),
        getattr(_APP, "_jobs", {}),
        getattr(_APP, "_schedules", {}),
    ):
        if _BARE_NAME in registry:
            return registry[_BARE_NAME]
    raise RuntimeError(
        f"resource_id={_RESOURCE_ID!r} did not resolve to a callable on app={_APP!r}"
    )


async def _invoke_async(payload: dict[str, Any]) -> Any:
    fn = _resolve_callable()
    inner = getattr(fn, "__wrapped__", fn)
    if asyncio.iscoroutinefunction(inner):
        return await fn(**payload)
    return fn(**payload)


async def _handle_invocation(request: Request) -> JSONResponse:
    try:
        raw = await request.body()
        payload = json.loads(raw) if raw else {}
        if not isinstance(payload, dict):
            payload = {"payload": payload}
    except json.JSONDecodeError:
        payload = {}
    result = await _invoke_async(payload)
    return JSONResponse({"result": result})


def _build_app() -> Starlette:
    routes: list[Any] = [
        Route(f"/_skaal/fn/{_BARE_NAME}", _handle_invocation, methods=["POST"]),
        Route(f"/_skaal/schedule/{_BARE_NAME}", _handle_invocation, methods=["POST"]),
        Route(f"/_skaal/job/{_BARE_NAME}", _handle_invocation, methods=["POST"]),
        Route("/_skaal/health", _health, methods=["GET"]),
    ]
    if _KIND == "asgi_service":
        mounted = getattr(_APP, "_asgi_path_mounts", {})
        for path, asgi_app in mounted.items():
            routes.append(Mount(path, app=asgi_app))
    return Starlette(routes=routes)


async def _health(_request: Request) -> JSONResponse:
    return JSONResponse({"ok": True, "resource_id": _RESOURCE_ID, "kind": _KIND})


app = _build_app()
