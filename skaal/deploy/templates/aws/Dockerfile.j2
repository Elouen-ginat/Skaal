# Generated by `skaal build` from skaal/deploy/templates/aws/Dockerfile.j2.
# Edits to this file are overwritten on the next build.
FROM public.ecr.aws/lambda/python:{{ python_version }}

WORKDIR ${LAMBDA_TASK_ROOT}

# `uv` resolves the dependency tree from the generated `pyproject.toml`;
# every transitive dep flows through skaal's optional-dependency table,
# so the lambda image gets exactly what `[project].dependencies` (and the
# extras it references) declares — no bare pins live in this Dockerfile.
RUN pip install --no-cache-dir uv

COPY pyproject.toml ./
RUN uv pip install --no-cache --system --target ${LAMBDA_TASK_ROOT} -r pyproject.toml

COPY {{ user_package }} ./{{ user_package }}
COPY bootstrap.py handler.py ./

ENV SKAAL_APP={{ app_name }}
ENV SKAAL_ENV={{ env_name }}
ENV SKAAL_TARGET={{ target }}
ENV SKAAL_BOUND_FINGERPRINT={{ bound_fingerprint }}

CMD [ "handler.lambda_handler" ]
