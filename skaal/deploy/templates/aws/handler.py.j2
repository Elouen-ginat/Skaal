"""AWS Lambda entry point generated by `skaal build`.

This file is rendered from `skaal/deploy/templates/aws/handler.py.j2`,
once per `BoundResource`. The resource identity (id, kind, bare name)
is fixed at build time and templated in below — no env-var lookup, no
string parsing at invocation time.

Dispatch is keyed by event payload shape: API Gateway HTTP v2 events
route through the user's ASGI app, EventBridge events route to a
schedule callable, and direct invocations (or SQS records) route to
the function this Lambda was built for.

Edits to this file are overwritten on the next build.
"""

from __future__ import annotations

import asyncio
import json
from typing import Any

from mangum import Mangum

from bootstrap import load_app, warm_up

_APP = load_app()
warm_up(_APP)

# Resource identity is fixed at build time — no runtime string parsing.
_RESOURCE_ID = "{{ resource_id }}"
_KIND = "{{ resource_kind }}"
_BARE_NAME = "{{ resource_bare_name }}"
_ASGI_HANDLER: Any | None = None


def _resolve_callable() -> Any:
    for registry in (
        getattr(_APP, "_functions", {}),
        getattr(_APP, "_jobs", {}),
        getattr(_APP, "_schedules", {}),
    ):
        if _BARE_NAME in registry:
            return registry[_BARE_NAME]
    raise RuntimeError(
        f"resource_id={_RESOURCE_ID!r} did not resolve to a callable on app={_APP!r}"
    )


def _is_apigw_v2(event: dict[str, Any]) -> bool:
    return isinstance(event, dict) and event.get("version") == "2.0" and "requestContext" in event


def _is_eventbridge(event: dict[str, Any]) -> bool:
    return isinstance(event, dict) and "source" in event and "detail-type" in event


def _run_async(coro: Any) -> Any:
    return asyncio.get_event_loop().run_until_complete(coro)


def _invoke_function(payload: dict[str, Any]) -> dict[str, Any]:
    fn = _resolve_callable()
    inner = getattr(fn, "__wrapped__", fn)
    if asyncio.iscoroutinefunction(inner):
        result = _run_async(fn(**payload))
    else:
        result = fn(**payload)
    return {"statusCode": 200, "body": json.dumps({"result": result}, default=str)}


def _mounted_path() -> str | None:
    marker = "mount("
    start = _RESOURCE_ID.rfind(marker)
    if start == -1:
        return None
    start += len(marker)
    end = _RESOURCE_ID.find(")", start)
    if end == -1:
        return None
    return _RESOURCE_ID[start:end]


def _resolve_asgi_app() -> Any:
    mounts = getattr(_APP, "_asgi_path_mounts", {}) or {}
    path = _mounted_path()
    if path and path in mounts:
        return mounts[path]
    if len(mounts) == 1:
        return next(iter(mounts.values()))
    raise RuntimeError(
        f"resource_id={_RESOURCE_ID!r} did not resolve to a mounted ASGI app on app={_APP!r}"
    )


def _invoke_asgi(event: dict[str, Any], context: Any) -> dict[str, Any]:
    global _ASGI_HANDLER
    if _ASGI_HANDLER is None:
        _ASGI_HANDLER = Mangum(_resolve_asgi_app(), lifespan="off")
    return _ASGI_HANDLER(event, context)


def lambda_handler(event: dict[str, Any], context: Any) -> Any:
    """AWS Lambda entry point."""
    if _KIND == "asgi_service" or _is_apigw_v2(event):
        return _invoke_asgi(event, context)
    if _is_eventbridge(event):
        return _invoke_function({})
    if isinstance(event, dict) and "Records" in event:
        # SQS / EventBridge-pipes batch — fan out one invocation per record.
        responses: list[Any] = []
        for record in event["Records"]:
            body = record.get("body", "{}")
            try:
                payload = json.loads(body) if isinstance(body, str) else dict(body)
            except json.JSONDecodeError:
                payload = {"body": body}
            responses.append(_invoke_function(payload))
        return {"batchItemFailures": [], "responses": responses}
    return _invoke_function(event if isinstance(event, dict) else {"payload": event})
