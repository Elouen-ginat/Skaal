# EditorConfig — https://editorconfig.org
# Sync with ruff (line-length = 100) and yamllint (max = 120).
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 100

[*.{yml,yaml}]
indent_size = 2
max_line_length = 120

[*.{json,toml}]
indent_size = 2

[*.{md,markdown}]
trim_trailing_whitespace = false  # preserve hard line breaks
indent_size = 2

[*.{rs}]
indent_size = 4
max_line_length = 100

[Makefile]
indent_style = tab

[*.{j2,jinja,jinja2}]
# Templates may exceed limits / use mixed indentation.
trim_trailing_whitespace = false
max_line_length = off
